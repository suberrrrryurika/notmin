{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mini_note",
  "version": "0.1.0",
  "identifier": "com.yurika.notmin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mini_note",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "center": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}